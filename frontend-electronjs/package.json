{
  "homepage": ".",
  "name": "dawn-auto-light-pos",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "dependencies": {
    "@faceio/fiojs": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "face-api.js": "^0.22.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "web-vitals": "^2.1.4"
  },
"build": {
  "appId": "com.dawn.autolight.pos",
  "productName": "Dawn Auto Light POS",

  "directories": {
    "buildResources": "public"
  },

  "files": [
    "build/**/*",
    "main.js",
    "package.json"
  ],

  "extraMetadata": {
    "main": "main.js"
  },

  "win": {
    "target": "nsis",
    "icon": "public/favicon.ico"
  }
},
  "scripts": {
    "build": "react-scripts build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}